#define CONFIG_WIRELESS

// Atlas-specific ZMK_BASE_LAYER wrapper.
//
// Extends base.keymap's 5-col-per-side / 3-thumb layout with:
//   - Number row (row 3):  GRAVE 1 2 3 4 5 | 6 7 8 9 0 EQUAL  (always accessible)
//   - Outer column:        TAB / ESC / [  on left
//                          BSPC / ' / ]   on right
//   - Two extra thumbs:    LALT (far-left) and RALT (far-right)
//   - Two transparent thumbs next to the outer thumbs (___)
//
// Layout diagram (one half shown):
//
//  ┌──────┬────┬────┬────┬────┬────┐     ┌────┬────┬────┬────┬────┬──────┐
//  │GRAVE │ 1  │ 2  │ 3  │ 4  │ 5  │     │ 6  │ 7  │ 8  │ 9  │ 0  │  =   │
//  ├──────┼────┼────┼────┼────┼────┤     ├────┼────┼────┼────┼────┼──────┤
//  │ TAB  │    │    │ LT │    │    │     │    │    │ RT │    │    │ BSPC │
//  ├──────┼────┼────┼────┼────┼────┤     ├────┼────┼────┼────┼────┼──────┤
//  │ ESC  │    │    │ LM │    │    │     │    │    │ RM │    │    │  '   │
//  ├──────┼────┼────┼────┼────┼────┤     ├────┼────┼────┼────┼────┼──────┤
//  │  [   │    │    │ LB │    │    │     │    │    │ RB │    │    │  ]   │
//  └──────┴────┴────┴────┴────┴────┘     └────┴────┴────┴────┴────┴──────┘
//              ┌──────┬────┬────┬────┬────┐ ┌────┬────┬────┬────┬──────┐
//              │ LALT │ ___│    │ LH │    │ │    │ RH │    │ ___│ RALT │
//              └──────┴────┴────┴────┴────┘ └────┴────┴────┴────┴──────┘

#define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)               \
    ZMK_LAYER(name,                                                           \
        /* row 3: number row */                                               \
        &kp GRAVE &kp N1  &kp N2  &kp N3  &kp N4  &kp N5                    \
        &kp N6    &kp N7  &kp N8  &kp N9  &kp N0  &kp EQUAL                 \
        /* row 2: top alpha */                                                \
        &kp TAB   LT                              RT   &kp BSPC              \
        /* row 1: home row */                                                 \
        &kp ESC   LM                              RM   &kp SQT               \
        /* row 0: bottom row */                                               \
        &kp LBKT  LB                              RB   &kp RBKT              \
        /* row 4: thumbs — 2 extra outer each side */                        \
        &kp LALT  ___     LH                      RH   ___      &kp RALT     \
    )

#include "atlas-key-labels.h"
#include "base.keymap"
